---
import Layout from '../../layouts/Layout.astro';

// Import all README.md files from public/article at build time (Vite)
const rawFiles = import.meta.glob('/public/article/*/README.md', { as: 'raw', eager: true });

const articles = Object.entries(rawFiles).map(([filePath, content]) => {
  // Extract slug from path: /public/article/SLUG/README.md
  const slug = filePath.split('/')[3];

  const titleMatch = (content as string).match(/^#\s+(.*)/m);
  const title = titleMatch ? titleMatch[1] : slug;

  const imgMatch = (content as string).match(/!\[.*?\]\((.*?)\)/);
  const coverImage = imgMatch ? `/article/${slug}/${imgMatch[1]}` : null;

  return { slug, title, coverImage };
});
---

<Layout title="Artículos · OFTE" description="Explora nuestros artículos, investigaciones y entrevistas exclusivas.">
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      
      <!-- Header -->
      <div class="mb-12 md:mb-16 text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-primary-900 via-primary-700 to-primary-500 dark:from-primary-100 dark:via-primary-300 dark:to-primary-600 sm:text-5xl">
          Artículos y Entrevistas
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-primary-950/70 dark:text-primary-200/70">
          Descubre las últimas novedades, investigaciones de frontera y conversaciones a fondo con exponentes del mundo de la física.
        </p>
      </div>

      <!-- Articles Grid -->
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <a
            href={`/article/${article.slug}`}
            class="group flex flex-col overflow-hidden rounded-2xl bg-white/50 dark:bg-primary-900/50 border border-primary-200/60 dark:border-primary-700/40 hover:shadow-xl hover:shadow-primary-700/10 dark:hover:shadow-primary-400/5 hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm"
          >
            {article.coverImage ? (
              <div class="aspect-[16/10] w-full overflow-hidden bg-primary-100 dark:bg-primary-800">
                <img
                  src={article.coverImage}
                  alt={article.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-[16/10] w-full bg-primary-100/50 dark:bg-primary-800/50 flex flex-col items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400 dark:text-primary-600">
                  <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span class="text-sm font-medium text-primary-500 dark:text-primary-500">Artículo de Texto</span>
              </div>
            )}
            
            <div class="flex flex-1 flex-col p-6 sm:p-8">
              <div class="flex-1">
                <h3 class="text-xl font-semibold leading-snug tracking-tight text-primary-900 dark:text-primary-50">
                  {article.title}
                </h3>
              </div>
              <div class="mt-6 flex items-center gap-2 text-sm font-medium text-primary-700 dark:text-primary-400 transition-colors group-hover:text-primary-800 dark:group-hover:text-primary-300">
                Leer artículo
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
        {articles.length === 0 && (
          <div class="col-span-1 sm:col-span-2 lg:col-span-3 text-center py-12">
            <p class="text-primary-600 dark:text-primary-400">Aún no se han publicado artículos.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
