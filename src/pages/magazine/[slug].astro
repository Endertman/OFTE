---
import Layout from "../../layouts/Layout.astro";
import { magazines } from "../../data/magazines";
import MagazineFlipbook from "../../components/magazine/MagazineFlipbook.jsx";

// Load all article READMEs at build time
const rawFiles = import.meta.glob('/public/article/*/README.md', { as: 'raw', eager: true });

const { slug } = Astro.params;
const magazine = magazines.find((m) => m.slug === slug);

if (!magazine) {
    return Astro.redirect("/404");
}

let relatedArticlesData: any[] = [];
if (magazine.relatedArticles) {
    for (const articleSlug of magazine.relatedArticles) {
        const filePath = `/public/article/${articleSlug}/README.md`;
        const content = rawFiles[filePath] as string | undefined;
        if (content) {
            const titleMatch = content.match(/^#\s+(.*)/m);
            const title = titleMatch ? titleMatch[1] : articleSlug;
            const imgMatch = content.match(/!\[.*?\]\((.*?)\)/);
            const coverImage = imgMatch ? `/article/${articleSlug}/${imgMatch[1]}` : null;
            relatedArticlesData.push({ slug: articleSlug, title, coverImage });
        }
    }
}
---

<Layout
    description={`Leer: ${magazine.title}`}
    title={`${magazine.title} · OFTE`}
>
    <section class="py-10 sm:py-16">
        <div
            class="mx-auto w-full px-4 sm:px-6 lg:px-8"
            style="max-width: 1250px;"
        >
            <!-- Back button -->
            <a
                href="/magazine"
                class="group mb-8 inline-flex items-center gap-2 text-sm font-medium text-primary-600 dark:text-primary-400 transition-colors hover:text-primary-800 dark:hover:text-primary-200"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform group-hover:-translate-x-1"
                >
                    <path d="m15 18-6-6 6-6"></path>
                </svg>
                Volver a revistas
            </a>

            <!-- Flipbook -->
            <MagazineFlipbook
                client:only="react"
                folder={magazine.folder}
                pageCount={magazine.pageCount}
                filePattern={magazine.filePattern}
                title={magazine.title}
            />

            <!-- Related Articles -->
            {relatedArticlesData.length > 0 && (
                <div class="mt-20 pt-16 border-t border-primary-200/50 dark:border-primary-800/50">
                    <h3 class="text-2xl font-bold tracking-tight text-primary-900 dark:text-primary-50 mb-8 tracking-tight md:text-3xl text-center">
                        Artículos en esta Edición
                    </h3>
                    <div class="flex flex-wrap justify-center gap-6 sm:gap-8">
                        {relatedArticlesData.map((article) => (
                            <a
                                href={`/article/${article.slug}`}
                                class="w-full max-w-sm group flex flex-col overflow-hidden rounded-2xl bg-white/50 dark:bg-primary-900/50 border border-primary-200/60 dark:border-primary-700/40 hover:shadow-xl hover:shadow-primary-700/10 dark:hover:shadow-primary-400/5 hover:-translate-y-1 transition-all duration-300 backdrop-blur-sm"
                            >
                                {article.coverImage ? (
                                    <div class="aspect-[16/10] w-full overflow-hidden bg-primary-100 dark:bg-primary-800">
                                        <img
                                            src={article.coverImage}
                                            alt={article.title}
                                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            loading="lazy"
                                        />
                                    </div>
                                ) : (
                                    <div class="aspect-[16/10] w-full bg-primary-100/50 dark:bg-primary-800/50 flex items-center justify-center">
                                        <span class="text-primary-400">Artículo de Texto</span>
                                    </div>
                                )}
                                <div class="flex flex-1 flex-col p-6">
                                    <h4 class="text-lg font-semibold leading-snug tracking-tight text-primary-900 dark:text-primary-50 mb-4">
                                        {article.title}
                                    </h4>
                                    <div class="mt-auto flex items-center gap-2 text-sm font-medium text-primary-700 dark:text-primary-400 group-hover:text-primary-800 dark:group-hover:text-primary-300">
                                        Leer completo
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
                                            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                        </svg>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </div>
            )}
        </div>
    </section>
</Layout>
