---
interface Props {
    slug: string;
    title: string;
    description: string;
    coverImage: string;
}

const { slug, title, description, coverImage } = Astro.props;
---

<a
    href={`/magazine/${slug}`}
    class="group relative flex flex-col overflow-hidden rounded-2xl border border-primary-200/60 dark:border-primary-700/40 bg-white/50 dark:bg-primary-900/50 backdrop-blur-sm transition-all duration-300 hover:shadow-xl hover:shadow-primary-700/10 dark:hover:shadow-primary-400/5 hover:-translate-y-1"
>
    <!-- Cover image -->
    <div
        class="relative aspect-[3/4] w-full overflow-hidden bg-primary-100 dark:bg-primary-800"
    >
        <img
            src={coverImage}
            alt={`Portada de ${title}`}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
        />
        <!-- Gradient overlay -->
        <div
            class="absolute inset-0 bg-gradient-to-t from-primary-950/60 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        >
        </div>
        <!-- Read button on hover -->
        <div
            class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        >
            <span
                class="inline-flex items-center gap-2 rounded-full bg-primary-100/90 dark:bg-primary-700/90 px-6 py-3 text-sm font-medium text-primary-900 dark:text-primary-50 backdrop-blur-sm shadow-lg"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                </svg>
                Leer revista
            </span>
        </div>
    </div>

    <!-- Info -->
    <div class="flex flex-col gap-2 p-5">
        <h2
            class="text-lg font-medium tracking-tight text-primary-900 dark:text-primary-50 line-clamp-2"
        >
            {title}
        </h2>
        <p class="text-sm text-primary-600 dark:text-primary-400 line-clamp-2">
            {description}
        </p>
    </div>
</a>
