---
const slides = [
  {
    title: 'Seminarios OFTE',
    highlight: '· Seminarios',
    description:
      'Explora nuestros seminarios de Física teórica y experimental. Un espacio donde el conocimiento se comparte y las ideas cobran vida a través de presentaciones y discusiones académicas.',
    cta: 'Ver seminarios',
    href: '/workshops',
    accent: 'from-indigo-600/20 via-purple-600/10 to-transparent',
    accentDark: 'dark:from-indigo-400/15 dark:via-purple-400/5 dark:to-transparent',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>`,
  },
  {
    title: 'Revista OFTE',
    highlight: '· Revista',
    description:
      'Descubre nuestra revista académica con artículos de investigación, ensayos y contribuciones de la comunidad universitaria en el campo de la Física.',
    cta: 'Ver Revista',
    href: '/magazine',
    accent: 'from-emerald-600/20 via-teal-600/10 to-transparent',
    accentDark: 'dark:from-emerald-400/15 dark:via-teal-400/5 dark:to-transparent',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>`,
  },
  {
    title: 'Artículos y Novedades',
    highlight: '· Novedades',
    description:
      'Mantente al día con las últimas novedades, artículos destacados y noticias del mundo de la Física. Un espacio para explorar los avances más recientes.',
    cta: 'Ver artículos',
    href: '/magazine',
    accent: 'from-amber-600/20 via-orange-600/10 to-transparent',
    accentDark: 'dark:from-amber-400/15 dark:via-orange-400/5 dark:to-transparent',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6V7.5Z" /></svg>`,
  },
];
---

<section class="relative min-h-[100svh] flex items-center overflow-hidden" id="hero-carousel">
  <!-- Background gradient accents per slide -->
  {slides.map((slide, i) => (
    <div
      class={`hero-bg absolute inset-0 bg-gradient-to-br ${slide.accent} ${slide.accentDark} transition-opacity duration-700 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
      data-bg-index={i}
    />
  ))}

  <div class="relative z-10 mx-auto w-full max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8 py-24 sm:py-32">
    <!-- Slides container -->
    <div class="relative w-full" style="min-height: 380px;">
      {slides.map((slide, i) => (
        <div
          class={`hero-slide absolute inset-0 flex flex-col items-start justify-center gap-6 sm:gap-8 transition-all duration-700 ease-in-out ${i === 0 ? 'opacity-100 translate-x-0 pointer-events-auto' : 'opacity-0 translate-x-8 pointer-events-none'}`}
          data-slide-index={i}
        >
          <!-- Icon badge -->
          <div class="text-primary-700 dark:text-primary-300 opacity-80 mb-2">
            <Fragment set:html={slide.icon} />
          </div>

          <div class="flex max-w-2xl flex-col items-start gap-4 sm:gap-6">
            <h1 class="text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl leading-tight">
              {slide.title.replace(slide.highlight.replace('· ', ''), '')}
              <b class="text-primary-700 dark:text-primary-400">{slide.highlight}</b>
            </h1>
            <p class="text-primary-950/70 dark:text-primary-200/70 text-lg sm:text-xl lg:text-2xl max-w-xl leading-relaxed">
              {slide.description}
            </p>
          </div>

          <a
            href={slide.href}
            class="group bg-primary-700 dark:bg-primary-400 hover:bg-primary-800 dark:hover:bg-primary-300 focus-visible:outline-primary-600 dark:focus-visible:outline-primary-400 dark:text-primary-950 mt-4 inline-flex items-center justify-center gap-2 rounded-full border border-transparent px-6 py-3 sm:px-8 sm:py-4 text-base font-medium text-white transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            {slide.cta}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Dots navigation -->
    <div class="mt-12 sm:mt-16 flex items-center gap-3">
      {slides.map((_, i) => (
        <button
          class={`hero-dot h-2.5 w-2.5 rounded-full transition-all duration-200 cursor-pointer ${i === 0 ? 'bg-primary-700 dark:bg-primary-400 w-8' : 'bg-primary-300 dark:bg-primary-700 hover:bg-primary-400 dark:hover:bg-primary-600'}`}
          data-dot-index={i}
          aria-label={`Ir al slide ${i + 1}`}
        />
      ))}
      <!-- Progress bar for current slide -->
      <div class="ml-4 flex-1 max-w-[120px] h-0.5 bg-primary-200 dark:bg-primary-800 rounded-full overflow-hidden hidden sm:block">
        <div class="hero-progress h-full bg-primary-600 dark:bg-primary-400 rounded-full" style="width: 0%; transition: width 5s linear;" />
      </div>
    </div>
  </div>
</section>

<script>
  // Script executes eagerly when component loads
  const initCarousel = () => {
    const carousel = document.getElementById('hero-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('.hero-slide');
    const dots = carousel.querySelectorAll('.hero-dot');
    const bgs = carousel.querySelectorAll('.hero-bg');
    const progress = carousel.querySelector('.hero-progress');
    const totalSlides = slides.length;
    
    if (totalSlides === 0) return;

    let currentSlide = 0;
    let interval: ReturnType<typeof setInterval> | undefined;

    function goToSlide(index) {
      if (index === currentSlide) return;
      
      // Hide current slide
      slides[currentSlide].classList.remove('opacity-100', 'translate-x-0', 'pointer-events-auto');
      slides[currentSlide].classList.add('opacity-0', '-translate-x-8', 'pointer-events-none');

      // Deactivate current dot
      dots[currentSlide].classList.remove('bg-primary-700', 'dark:bg-primary-400', 'w-8');
      dots[currentSlide].classList.add('bg-primary-300', 'dark:bg-primary-700');

      // Hide current bg
      bgs[currentSlide].classList.remove('opacity-100');
      bgs[currentSlide].classList.add('opacity-0');

      currentSlide = index;

      // Show new slide (comes from right)
      slides[currentSlide].classList.remove('opacity-0', 'translate-x-8', '-translate-x-8', 'pointer-events-none');
      slides[currentSlide].classList.add('opacity-100', 'translate-x-0', 'pointer-events-auto');

      // Activate new dot
      dots[currentSlide].classList.remove('bg-primary-300', 'dark:bg-primary-700');
      dots[currentSlide].classList.add('bg-primary-700', 'dark:bg-primary-400', 'w-8');

      // Show new bg
      bgs[currentSlide].classList.remove('opacity-0');
      bgs[currentSlide].classList.add('opacity-100');

      // Reset progress
      resetProgress();
    }

    function nextSlide() {
      goToSlide((currentSlide + 1) % totalSlides);
    }

    function resetProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width = '0%';
      // Trigger reflow
      void progress.offsetHeight;
      progress.style.transition = 'width 5s linear';
      progress.style.width = '100%';
    }

    function startAutoPlay() {
      resetProgress();
      clearInterval(interval);
      interval = setInterval(() => {
        nextSlide();
      }, 5000);
    }

    function stopAutoPlay() {
      clearInterval(interval);
      if (progress) {
        progress.style.transition = 'none';
        progress.style.width = '0%';
      }
    }

    // Dot click handlers
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(i);
        startAutoPlay();
      });
    });

    // Touch swipe support for mobile
    let touchStartX = 0;
    let touchEndX = 0;

    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const diff = touchStartX - touchEndX;
      // swipe threshold
      if (Math.abs(diff) > 50) {
        stopAutoPlay();
        if (diff > 0) {
          // Swipe left -> next
          goToSlide((currentSlide + 1) % totalSlides);
        } else {
          // Swipe right -> prev
          goToSlide((currentSlide - 1 + totalSlides) % totalSlides);
        }
        startAutoPlay();
      }
    }

    // Start
    startAutoPlay();
  };

  // Run on first load
  initCarousel();
</script>
